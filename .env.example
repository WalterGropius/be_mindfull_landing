# Transactional e-mail (contact form + free-course sign-ups).
# Backed by Resend (https://resend.com). The sending domain must be verified
# in Resend before MAIL_FROM will deliver.
RESEND_API_KEY=
MAIL_FROM="Be Mindful <noreply@bemindful.cz>"
CONTACT_TO=info@bemindful.cz

